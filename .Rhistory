# 1. Sequence identity matrix
mat <- matrix(c(
100, 85, 33, 33, 35, 52,
85, 100, 37, 33, 37, 43,
33, 37, 100, 69, 71, 59,
33, 33, 69, 100, 72, 60,
35, 37, 71, 72, 100, 62,
52, 43, 59, 60, 62, 100
), nrow = 6, byrow = TRUE)
labels <- c(
"CserDQD/SDH1.1",
"CserDQD/SDH1.2",
"CserDQD/SDH2",
"CserDQD/SDH3",
"CserDQD/SDH4",
"CserDQD/SDH5"
)
rownames(mat) <- labels
colnames(mat) <- labels
nwk <- "(CserDQD/SDH1.1:2.2796e-06,CserDQD/SDH1.2:2.3774e-06,((CserDQD/SDH2:0.215848,(CserDQD/SDH3:0.232711,CserDQD/SDH4:0.227801):0.090552):0.450486,CserDQD/SDH5:0.206075):0.376259);"
tree <- read.tree(text = nwk)
# Root the tree using one tip as outgroup
tree_rooted <- root(tree, outgroup = "CserDQD/SDH5", resolve.root = TRUE)
# Optional check
print(is.rooted(tree_rooted))  # should be TRUE
# 3. Make branch lengths suitable for dendrogram conversion
tree_grafen <- compute.brlen(tree_rooted, method = "Grafen")
# Convert phylo -> hclust -> dendrogram
hc <- as.hclust(tree_grafen)
dend <- as.dendrogram(hc)
# Reorder matrix to match tree
tip_order <- hc$labels[hc$order]
mat_ord <- mat[tip_order, tip_order]
# 3. Mid-contrast publication palette
my_cols <- colorRampPalette(c(
"#f7fbff", "#c6dbef", "#6b92d6", "#fddbc7", "#f4a582"
))(100)
# 4. Save as PNG
png("sequence_identity_tree_heatmap.png", width = 2600, height = 1300, res = 300)
heatmap.2(
mat_ord,
Rowv = dend,
Colv = NA,
dendrogram = "row",
trace = "none",
key = TRUE,
key.title = "Identity",
key.xlab = "%",
#key.par=list(mar=c(4,4,6,4)),
density.info = "none",
col = my_cols,
breaks = seq(0, 100, length.out = 101),
cellnote = mat_ord,   # add % sign
notecol = "black",
notecex = 1.0,
font = 2,                          # <-- THIS makes them bold
margins = c(12, 16),
sepcolor = "grey85",
colsep = 1:ncol(mat_ord),
rowsep = 1:nrow(mat_ord),
cexRow = 1.1,
cexCol = 1.0,
srtCol = 45,
labRow = rownames(mat_ord),
labCol = colnames(mat_ord)
)
dev.off()
heatmap.2(
mat_ord,
Rowv = NA,
Colv = dend,
dendrogram = "column",
trace = "none",
key = TRUE,
key.title = "Identity",
key.xlab = "%",
density.info = "none",
col = my_cols,
breaks = seq(0, 100, length.out = 101),
cellnote = mat_ord,   # add % sign
notecol = "black",
notecex = 1.0,
font = 2,                          # <-- THIS makes them bold
margins = c(12, 16),
sepcolor = "grey85",
colsep = 1:ncol(mat_ord),
rowsep = 1:nrow(mat_ord),
cexRow = 1.1,
cexCol = 1.0,
srtCol = 45,
labRow = rownames(mat_ord),
labCol = colnames(mat_ord)
)
heatmap.2(
mat_ord,
Rowv = NA,
Colv = dend,
dendrogram = "column",
trace = "none",
key = F,
key.title = "Identity",
key.xlab = "%",
density.info = "none",
col = my_cols,
breaks = seq(0, 100, length.out = 101),
cellnote = mat_ord,   # add % sign
notecol = "black",
notecex = 1.0,
font = 2,                          # <-- THIS makes them bold
margins = c(12, 16),
sepcolor = "grey85",
colsep = 1:ncol(mat_ord),
rowsep = 1:nrow(mat_ord),
cexRow = 1.1,
cexCol = 1.0,
srtCol = 45,
labRow = rownames(mat_ord),
labCol = colnames(mat_ord)
)
